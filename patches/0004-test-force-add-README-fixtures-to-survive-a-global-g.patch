From 15e3add7b796a5cfe6871901ead0db7f53fe27bd Mon Sep 17 00:00:00 2001
From: Michael Lerman <mlerman@ironscales.com>
Date: Tue, 9 Jun 2026 14:24:10 +0300
Subject: [PATCH 4/6] test: force-add README fixtures to survive a global
 gitignore

The temp-repo fixtures did 'git add README.md', which fails when the
developer's global core.excludesfile ignores markdown (e.g. **/*.md).
Use 'git add -f' so the fixtures commit regardless of host git config.

Co-authored-by: Cursor <cursoragent@cursor.com>
---
 tests/extension-commands.test.ts |  2 +-
 tests/extension-worktree.test.ts |  4 ++--
 tests/worktree-security.test.ts  | 26 +++++++++++++++++++-------
 3 files changed, 22 insertions(+), 10 deletions(-)

diff --git a/tests/extension-commands.test.ts b/tests/extension-commands.test.ts
index e7c5967..afe84b6 100644
--- a/tests/extension-commands.test.ts
+++ b/tests/extension-commands.test.ts
@@ -56,7 +56,7 @@ function createTestRepo(dir: string): string {
   execSync("git config user.email test@example.com", { stdio: "pipe" });
   execSync("git config user.name test", { stdio: "pipe" });
   writeFileSync("README.md", "x\n", "utf-8");
-  execSync("git add README.md && git commit -m init", {
+  execSync("git add -f README.md && git commit -m init", {
     stdio: "pipe",
     shell: "/bin/bash",
   });
