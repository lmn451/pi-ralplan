#SJ:    case \"plan\":\n 55#TX:      return \"plan.md\";\n 56#BR:    case \"test-spec\":\n 57#TN:      return \"test-spec.md\";\n 58#NY:  }\n 59#PY:}\n 60#HQ:\n 61#VQ:function readFileSafe(path: string): string | null {\n 62#JQ:  try {\n 63#KN:    return readFileSync(path, \"utf-8\");\n 64#PZ:  } catch {\n 65#MW:    return null;\n 66#HM:  }\n 67#PQ:}\n 68#RT:\n 69#RV:function escapeRegex(value: string): string {\n 70#TB:  return value.replace(/[.*+?^${}()|[\\]\\\\]/g, \"\\\\$&\");\n 71#JV:}\n 72#SV:\n 73#MJ:export function getSectionContent(\n 74#HB:  markdown: string,\n 75#WN:  heading: string,\n 76#NY:): string | null {\n 77#NN:  const headingRe = new RegExp(`^##\\\\s+${escapeRegex(heading)}[ \\\\t]*$`, \"im\");\n 78#RY:  const headingMatch = headingRe.exec(markdown);\n 79#NB:  if (!headingMatch || headingMatch.index === undefined) return null;\n 80#KB:\n 81#XZ:  const bodyStart = headingMatch.index + headingMatch[0].length;\n 82#QB:  const rest = markdown.slice(bodyStart).replace(/^\\r?\\n/, \"\");\n 83#QM:  const nextHeadingMatch = /\\r?\\n##\\s+/.exec(rest);\n 84#VJ:  const body = (\n 85#WW:    nextHeadingMatch ? rest.slice(0, nextHeadingMatch.index) : rest\n 86#WT:  ).trim();\n 87#MN:  return body.length > 0 ? body : null;\n 88#NW:}\n 89#WY:\n 90#BM:function hasRequiredSections(markdown: string, headings: string[]): boolean {\n 91#NP:  return headings.every(\n 92#JK:    (heading) => getSectionContent(markdown, heading) !== null,\n 93#KY:  );\n 94#RR:}\n 95#MS:\n 96#XJ:function sortArtifactPathsDescending(paths: string[]): string[] {\n 97#JR:  return [...paths].sort((a, b) => {\n 98#KS:    const fileCompare = basename(b).localeCompare(basename(a));\n 99#RJ:    if (fileCompare !== 0) return fileCompare;\n100#PR:    return b.localeCompare(a);\n101#MV:  });\n102#SZ:}\n103#YS:\n104#VB:/** Read planning artifacts from plans directory */\n105#VW:export function readPlanningArtifacts(cwd: string): PlanningArtifacts {\n106#YJ:  const plansDir = resolvePlansDir(cwd);\n107#PP:  const prdPaths: string[] = [];\n108#TN:  const planPaths: string[] = [];\n109#WV:  const testSpecPaths: string[] = [];\n110#WY:\n111#RH:  if (!existsSync(plansDir)) {\n112#RB:    return { specPaths: [], planPaths: [], testSpecPaths: [] };\n113#TR:  }\n114#BJ:\n115#ST:  let entries: string[];\n116#JQ:  try {\n117#MK:    entries = readdirSync(plansDir);\n118#PZ:  } catch {\n119#RB:    return { specPaths: [], planPaths: [], testSpecPaths: [] };\n120#SX:  }\n121#QY:\n122#NQ:  for (const entry of entries) {\n123#ZN:    if (!entry.endsWith(\".md\")) continue;\n124#MY:    const fullPath = join(plansDir, entry);\n125#YZ:    if (entry.startsWith(\"spec-\") || entry === \"spec.md\") {\n126#BK:      prdPaths.push(fullPath);\n127#KS:    } else if (entry.startsWith(\"plan-\") || entry === \"plan.md\") {\n128#BR:      planPaths.push(fullPath);\n129#NK:    } else if (entry.startsWith(\"test-spec-\") || entry === \"test-spec.md\") {\n130#BP:      testSpecPaths.push(fullPath);\n131#BM:    }\n132#BY:  }\n133#BM:\n134#ZV:  return {\n135#MS:    specPaths: sortArtifactPathsDescending(prdPaths),\n136#BX:    planPaths: sortArtifactPathsDescending(planPaths),\n137#MK:    testSpecPaths: sortArtifactPathsDescending(testSpecPaths),\n138#KJ:  };\n139#VW:}\n140#XS:\n141#JS:/** Returns true when latest spec and plan contain required quality-gate sections */\n142#XQ:export function isPlanningComplete(artifacts: PlanningArtifacts): boolean {\n143#VW:  if (artifacts.specPaths.length === 0 || artifacts.planPaths.length === 0) {\n144#HS:    return false;\n145#PV:  }\n146#JM:\n147#ZQ:  const latestSpec = readFileSafe(artifacts.specPaths[0]);\n148#KR:  const latestPlan = readFileSafe(artifacts.planPaths[0]);\n149#KY:  if (!latestSpec || !latestPlan) return false;\n150#PY:\n151#MP:  return (\n152#BV:    hasRequiredSections(latestSpec, [\n153#VN:      \"Acceptance criteria\",\n154#TS:      \"Requirement coverage map\",\n155#XK:    ]) &&\n156#RY:    hasRequiredSections(latestPlan, [\n157#PB:      \"Architecture Decision Record (ADR)\",\n158#TP:      \"Task Breakdown\",\n159#RK:      \"Dependency Graph\",\n160#MX:      \"Acceptance Criteria per Task\",\n161#QX:      \"Risk Register\",\n162#YS:    ])\n163#ZV:  );\n164#QX:}\n165#NX:\n166#PJ:/** Write an artifact file to the plans directory */\n167#NV:export function writeArtifact(\n168#XN:  cwd: string,\n169#XJ:  filename: string,\n170#RM:  content: string,\n171#XJ:): string {\n172#VV:  const dir = ensureRalplanDir(cwd);\n173#JW:  const path = join(dir, filename);\n174#RV:  writeFileSync(path, content, \"utf-8\");\n175#JR:  return path;\n176#TY:}\n177#HM:\n178#KR:/** Append content to an artifact file in the plans directory */\n179#SJ:export function appendArtifact(\n180#XN:  cwd: string,\n181#XJ:  filename: string,\n182#RM:  content: string,\n183#XJ:): string {\n184#VV:  const dir = ensureRalplanDir(cwd);\n185#JW:  const path = join(dir, filename);\n186#ZN:  appendFileSync(path, content, \"utf-8\");\n187#JR:  return path;\n188#WH:}"}],"details":{"snapshotId":"v1|/Users/applesucks/dev/pi-ralplan/pi/extensions/ralplan/artifacts.ts|1778837803596.2195|5185","metrics":{"truncated":false}},"isError":false,"timestamp":1779434401546}}
