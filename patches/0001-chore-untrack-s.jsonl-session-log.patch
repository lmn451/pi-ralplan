e will be created for this plan.\n 52#NM:\n 53#KT:- **Worktree Name:** \\`${worktreeName}\\`\n 54#JK:- **Worktree Path:** \\`${worktreeRoot}/${worktreeName}\\`\n 55#RW:- **Base Branch:** main (configurable)\n 56#XN:\n 57#BZ:The worktree isolates this plan's work from the main repository.\n 58#ZH:`;\n 59#PY:}\n 60#HQ:\n 61#MQ:/** Get date-based filename section */\n 62#YV:function getDateBasedNamingSection(): string {\n 63#BX:  const today = formatDate();\n 64#NW:  return `\n 65#QH:### Date-Based Naming\n 66#JQ:\n 67#RY:Plan and spec files use human-readable date-based filenames:\n 68#QX:- Spec: \\`spec-${today}-{short-description}.md\\`\n 69#WT:- Plan: \\`plan-${today}-{short-description}.md\\`\n 70#YY:\n 71#MK:This ensures easy navigation and historical tracking.\n 72#SS:`;\n 73#XV:}\n 74#HQ:\n 75#QT:/** Get ADR template section */\n 76#VZ:function getADRSection(): string {\n 77#NW:  return `\n 78#XR:### Architecture Decision Record (ADR)\n 79#BR:\n 80#NP:The plan artifact MUST include an ADR section that captures the full planning flow:\n 81#JQ:\n 82#WH:\\`\\`\\`markdown\n 83#VH:## Architecture Decision Record\n 84#WR:\n 85#BM:### Open Questions\n 86#YH:- [ ] **Question** — Why it matters\n 87#XB:\n 88#WN:### Plan Iterations\n 89#HZ:- **Iteration N**: Title\n 90#WB:  - Description of architect/critic feedback\n 91#RP:  - Status: pending/approved/rejected\n 92#JZ:\n 93#SS:### Tradeoffs Discussed\n 94#BB:- **Tradeoff Title**\n 95#TZ:  - Options considered:\n 96#BN:    - Option A\n 97#JZ:    - Option B\n 98#JN:  - Rejected alternatives:\n 99#KW:    - ✗ Rejected option\n100#YB:  - Decision: Why this choice\n101#ZS:\n102#XN:### Architect Reviews\n103#HV:- **Review Title** [status]\n104#YZ:  - Feedback: Architect's technical assessment\n105#VS:\n106#KQ:### Critic Reviews\n107#HV:- **Review Title** [status]\n108#XK:  - Feedback: Critic's challenge points\n109#BP:\n110#QY:### Decisions\n111#SN:- **Decision Title** — Description [status: pending/approved/rejected]\n112#QJ:\n113#RR:### Approvals\n114#MV:- ✓ **Approved Item** by [author] at [timestamp]\n115#PV:\n116#XS:### Rejections\n117#PH:- ✗ **Rejected Item** by [author]: [reason]\n118#BW:\\`\\`\\`\n119#YR:\n120#JS:Track all iterations, tradeoffs, reviews, decisions, approvals, and rejections.\n121#VP:`;\n122#PT:}\n123#WY:\n124#ZW:export const ralplanAdapter: PipelineStageAdapter = {\n125#KJ:  id: \"ralplan\",\n126#TP:  name: \"Planning (RALPLAN)\",\n127#YJ:  completionSignal: RALPLAN_COMPLETION_SIGNAL,\n128#YX:\n129#SS:  shouldSkip(config: PipelineConfig): boolean {\n130#TQ:    return config.planning === false;\n131#VQ:  },\n132#QZ:\n133#BX:  // Note: worktree creation is handled in index.ts command handlers\n134#KZ:  // to properly store the path in state\n135#VN:  onEnter(_context: PipelineContext): void {\n136#JP:    // Worktree is created in /ralplan or /brainstorm command handlers\n137#XQ:  },\n138#KK:\n139#ZW:  getPrompt(context: PipelineContext): string {\n140#TS:    // Brainstorm mode dispatch\n141#SP:    if (context.mode === \"brainstorm\") {\n142#VX:      const sub = context.brainstorm?.subPhase ?? \"expanding\";\n143#QH:      switch (sub) {\n144#SN:        case \"expanding\":\n145#ZR:          return getBrainstormExpansionPrompt(context);\n146#TZ:        case \"awaiting-answers\":\n147#WP:          // Steering prompt to keep AI from going off-track\n148#YS:          return getBrainstormSteeringPrompt();\n149#JK:        case \"planning\":\n150#SZ:          return getBrainstormResumePrompt(context);\n151#VV:        default:\n152#ZR:          return getBrainstormExpansionPrompt(context);\n153#RZ:      }\n154#QK:    }\n155#NT:\n156#BR:    // Existing ralplan mode\n157#XZ:    if (context.config.planning === \"ralplan\") {\n158#PN:      const basePrompt = getConsensusPlanningPrompt(context);\n159#RW:      return (\n160#XW:        getWorktreeCreationSection(context) +\n161#QX:        getDateBasedNamingSection() +\n162#WV:        getADRSection() +\n163#QM:        \"\\n---\\n\\n\" +\n164#TN:        basePrompt\n165#JJ:      );\n166#RV:    }\n167#QZ:\n168#RT:    // Direct planning mode\n169#PV:    const specPath = context.specPath || \"plans/spec.md\";\n170#KK:    const planPath = context.planPath || \"plans/plan.md\";\n171#VN:    return (\n172#JY:      getWorktreeCreationSection(context) +\n173#ZJ:      getDateBasedNamingSection() +\n174#SW:      getADRSection() +\n175#WW:      `\n176#NY:---\n177#HM:\n178#BV:## PLANNING (Direct)\n179#JZ:\n180#XR:Your task: Expand the idea into a spec and create an implementation plan.\n181#WS:\n182#QV:**Original Idea:** \"${context.idea}\"\n183#VB:\n184#NV:### Part 1: Idea Expansion\n185#HM:\n186#VT:Read the spec or create one at \\`${specPath}\\`\n187#YV:\n188#RH:### Part 2: Direct Planning\n189#RS:\n190#ZV:${getDirectPlanningPrompt(specPath, planPath)}\n191#BH:\n192#JJ:Save the plan to: \\`${planPath}\\`\n193#XN:\n194#YH:### Completion\n195#JZ:\n196#MS:When both the spec AND the plan are complete:\n197#MH:\n198#HZ:Signal: ${RALPLAN_COMPLETION_SIGNAL}`\n199#RK:    );\n200#TT:  },\n201#VR:};\n202#JM:\n203#MW:export const executionAdapter: PipelineStageAdapter = {\n204#VP:  id: \"execution\",\n205#QJ:  name: \"Execution\",\n206#BM:  completionSignal: EXECUTION_COMPLETION_SIGNAL,\n207#NH:\n208#SN:  shouldSkip(): boolean {\n209#HS:    return false;\n210#JN:  },\n211#YZ:\n212#ZW:  getPrompt(context: PipelineContext): string {\n213#KK:    const planPath = context.planPath || \"plans/plan.md\";\n214#RY:    return getExecutionPrompt(planPath, context.config.execution === \"team\");\n215#MN:  },\n216#VT:};\n217#BB:\n218#RB:export const ralphAdapter: PipelineStageAdapter = {\n219#PR:  id: \"ralph\",\n220#KN:  name: \"Verification (RALPH)\",\n221#JN:  completionSignal: RALPH_COMPLETION_SIGNAL,\n222#KK:\n223#SS:  shouldSkip(config: PipelineConfig): boolean {\n224#NS:    return config.verification === false;\n225#QJ:  },\n226#XJ:\n227#ZW:  getPrompt(context: PipelineContext): string {\n228#PV:    const specPath = context.specPath || \"plans/spec.md\";\n229#BP:    const maxIterations =\n230#XS:      context.config.verification !== false\n231#TZ:        ? context.config.verification.maxIterations\n232#JZ:        : 100;\n233#SY:    return getRalphPrompt(specPath, maxIterations);\n234#PZ:  },\n235#XM:};\n236#WZ:\n237#KM:export const qaAdapter: PipelineStageAdapter = {\n238#WM:  id: \"qa\",\n239#XK:  name: \"Quality Assurance\",\n240#MT:  completionSignal: QA_COMPLETION_SIGNAL,\n241#QW:\n242#SS:  shouldSkip(config: PipelineConfig): boolean {\n243#SH:    return !config.qa;\n244#BM:  },\n245#VJ:\n246#RT:  getPrompt(): string {\n247#ZT:    return `## QA (Quality Assurance)\n248#HB:\n249#TM:Run build/lint/test cycling until all checks pass.\n250#MT:\n251#ZY:${getQAPrompt()}\n252#TZ:\n253#YH:### Completion\n254#NZ:\n255#SR:When all QA checks pass:\n256#XK:\n257#QJ:Signal: ${QA_COMPLETION_SIGNAL}`;\n258#WB:  },\n259#JJ:};"}],"details":{"snapshotId":"v1|/Users/applesucks/dev/pi-ralplan/pi/extensions/ralplan/adapters.ts|1779131233367.4263|6548","metrics":{"truncated":false}},"isError":false,"timestamp":1779434401545}}
