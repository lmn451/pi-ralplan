xactly:\n441#NN:${BRAINSTORM_OPEN_QUESTIONS_READY}\n442#VN:\n443#HK:**IMPORTANT:** Do NOT proceed to consensus planning. Do NOT answer the open questions yourself. Stop and wait for the user.`;\n444#SP:}\n445#NP:\n446#QY:/** Generate the brainstorm steering prompt (awaiting-answers sub-phase) */\n447#ZP:export function getBrainstormSteeringPrompt(): string {\n448#HM:  return `## Brainstorm: Awaiting User Answers\n449#TS:\n450#TQ:The user is answering brainstorm questions. Acknowledge their response briefly. Do NOT implement, plan, or take action. Wait for the user to use /ralplan:done-answering to proceed, or /ralplan:skip-questions to skip.`;\n451#RS:}\n452#JQ:\n453#MM:/** Generate the brainstorm resume prompt (planning sub-phase) */\n454#WS:export function getBrainstormResumePrompt(context: PipelineContext): string {\n455#QZ:  const specPath = context.specPath || \"plans/spec.md\";\n456#KK:  const planPath = context.planPath || \"plans/plan.md\";\n457#NK:  const answersBlock = context.brainstorm\n458#TH:    ? formatAnswersForPrompt(context.brainstorm.answers)\n459#YV:    : \"\";\n460#XX:\n461#XN:  return `## BRAINSTORM — Continue Planning\n462#HM:\n463#YX:The user has provided answers to the open questions.\n464#QS:\n465#WP:**Original Idea:** \"${escapeForPrompt(context.idea)}\"\n466#JX:\n467#MN:${answersBlock || \"No specific answers were provided. Proceed with best-effort planning.\"}\n468#PW:\n469#BV:### Your Task\n470#XW:\n471#MZ:1. Read the answers above.\n472#MV:2. Continue expanding the idea into a full spec at \\`${specPath}\\`.\n473#TB:3. Proceed with consensus planning (Planner → Architect → Critic).\n474#JS:4. Save the plan to: \\`${planPath}\\`\n475#NX:\n476#YH:### Completion\n477#VB:\n478#MM:When both the spec AND the consensus plan are complete and approved:\n479#XY:\n480#KH:Signal: PIPELINE_RALPLAN_COMPLETE`;\n481#NR:}\n482#YY:\n483#KY:/** Generate the brainstorm awaiting prompt (user-facing, not an AI prompt) */\n484#HR:export function getBrainstor