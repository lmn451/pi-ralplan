ng; text?: string } => typeof c === \"object\" && c !== null)\n40#ST:        .filter((c) => c.type === \"text\")\n41#BN:        .map((c) => c.text ?? \"\")\n42#HW:        .join(\"\\n\");\n43#JS:    }\n44#KX:  }\n45#YB:  return null;\n46#PV:}"}],"details":{"snapshotId":"v1|/Users/applesucks/dev/pi-ralplan/pi/extensions/ralplan/signals.ts|1777477634297.8235|1673","metrics":{"truncated":false}},"isError":false,"timestamp":1779434401546}}
