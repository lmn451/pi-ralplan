tring,\n 52#SS:): BrainstormState {\n 53#ZV:  return {\n 54#WM:    ...state,\n 55#QY:    answers: [...state.answers, { question, answer }],\n 56#HY:  };\n 57#XW:}\n 58#KR:\n 59#KT:export function withQuestions(state: BrainstormState, questions: string[]): BrainstormState {\n 60#ZV:  return {\n 61#WM:    ...state,\n 62#BW:    questions,\n 63#JH:  };\n 64#YP:}\n 65#PZ:\n 66#VR:// ============================================================================\n 67#MT:// PREDICATES\n 68#VW:// ============================================================================\n 69#KB:\n 70#BX:export function isAwaitingAnswers(state: BrainstormState | undefined): boolean {\n 71#VV:  return state?.subPhase === \"awaiting-answers\";\n 72#BK:}\n 73#HV:\n 74#MW:export function isBrainstormMode(state: RalplanState | null): boolean {\n 75#XN:  return state?.mode === \"brainstorm\";\n 76#KK:}\n 77#VB:\n 78#BR:export function shouldSuppressSignals(state: RalplanState | null): boolean {\n 79#PB:  if (!state || state.mode !== \"brainstorm\") return false;\n 80#ZY:  const sub = state.brainstorm?.subPhase;\n 81#TX:  return sub === \"expanding\" || sub === \"awaiting-answers\";\n 82#PN:}\n 83#YX:\n 84#VK:// ============================================================================\n 85#YB:// FORMATTING & SANITIZATION\n 86#NW:// ============================================================================\n 87#XB:\n 88#XH:/** Sanitize user-provided content for safe prompt injection.\n 89#XR: *  Escapes triple backticks and known signal strings. */\n 90#SS:export function sanitizeForPrompt(text: string): string {\n 91#KN:  return text\n 92#VK:    .replace(/```/g, \"\\\\\\u0060\\\\\\u0060\\\\\\u0060\")\n 93#PS:    .replace(/PIPELINE_RALPLAN_COMPLETE/g, \"PIPELINE\\\\_RALPLAN\\\\_COMPLETE\")\n 94#TK:    .replace(/PIPELINE_EXECUTION_COMPLETE/g, \"PIPELINE\\\\_EXECUTION\\\\_COMPLETE\")\n 95#BV:    .replace(/PIPELINE_RALPH_COMPLETE/g, \"PIPELINE\\\\_RALPH\\\\_COMPLETE\")\n 96#PH:    .replace(/PIPELINE_QA_COMPLETE/g, \"PIPELINE\\\\_QA\\\\_COMPLETE\")\n 97#VW:    .replace(/BRAINSTORM_OPEN_QUESTIONS_READY/g, \"BRAINSTORM\\\\_OPEN\\\\_QUESTIONS\\\\_READY\");\n 98#VQ:}\n 99#BK:\n100#SB:/** Format Q+A pairs as markdown for prompt injection */\n101#RS:export function formatAnswersForPrompt(answers: QandA[]): string {\n102#RQ:  if (answers.length === 0) return \"\";\n103#QZ:  const lines = [\"### Answered Questions\", \"\"];\n104#JY:  for (const qa of answers) {\n105#WX:    lines.push(`**Q:** ${qa.question}`);\n106#YR:    lines.push(`**A:** ${sanitizeForPrompt(qa.answer)}`);\n107#PB:    lines.push(\"\");\n108#WW:  }\n109#VH:  return lines.join(\"\\n\");\n110#BT:}\n111#YX:\n112#PS:// ============================================================================\n113#RJ:// PARSING\n114#TY:// ============================================================================\n115#PV:\n116#KV:/** Parse open questions from markdown content.\n117#XX: *  Accepts both the simple test format and the brainstorm prompt format.\n118#TY: *  Returns empty array on failure (graceful degradation). */\n119#BH:export function parseOpenQuestions(markdown: string): string[] {\n120#JQ:  try {\n121#HB:    const headingMatch = markdown.match(/^##\\s+.*\\bOpen Questions\\b.*$/im);\n122#PR:    if (!headingMatch || headingMatch.index === undefined) return [];\n123#WY:\n124#YR:    const afterHeading = markdown\n125#WX:      .slice(headingMatch.index + headingMatch[0].length)\n126#PY:      .replace(/^\\r?\\n/, \"\");\n127#YZ:    const nextHeadingIndex = afterHeading.search(/\\r?\\n##\\s+/);\n128#XZ:    const section = (nextHeadingIndex >= 0\n129#PM:      ? afterHeading.slice(0, nextHeadingIndex)\n130#SQ:      : afterHeading).trim();\n131#QY:    if (!section) return [];\n132#QZ:\n133#WB:    return section\n134#SW:      .split(\"\\n\")\n135#JN:      .map((line) => line.trim())\n136#YN:      .filter((line) => /^(?:-|\\*|\\d+\\.)\\s+/.test(line))\n137#BV:      .filter((line) => !/^[-*]\\s*\\*\\*Why:\\*\\*/i.test(line))\n138#QM:      .map((line) => line.replace(/^(?:-|\\*|\\d+\\.)\\s*/, \"\"))\n139#QX:      .map((line) => line.replace(/^\\[[ xX]?\\]\\s*/, \"\"))\n140#MK:      .map((line) => line.replace(/^\\*\\*Q:\\*\\*\\s*/i, \"\"))\n141#KK:      .map((line) => line.replace(/\\s+—\\s+.*$/, \"\"))\n142#JN:      .map((line) => line.trim())\n143#ZM:      .filter(Boolean);\n144#PZ:  } catch {\n145#HS:    return [];\n146#YK:  }\n147#MQ:}\n148#SS:\n149#BH:/** Parse raw user text into a Q+A entry.\n150#NK: *  Maps text to known questions if possible, otherwise stores as freeform. */\n151#HV:export function parseUserAnswer(rawText: string, questions: string[]): QandA {\n152#XV:  // If there's exactly one unanswered question, map to it\n153#JY:  if (questions.length === 1) {\n154#KY:    return { question: questions[0], answer: rawText };\n155#YT:  }\n156#RQ:  // Otherwise, store as freeform\n157#KH:  return { question: \"[freeform]\", answer: rawText };\n158#RV:}\n159#XK:\n160#NY:// ============================================================================\n161#YH:// COMMAND HELPERS\n162#ZY:// ============================================================================\n163#VQ:\n164#PW:/** Skip questions — works from both expanding and awaiting-answers sub-phases */\n165#XW:export function skipQuestions(state: BrainstormState): BrainstormState {\n166#ZV:  return {\n167#HX:    ...transitionSubPhase(state, \"planning\"),\n168#QW:    answers: [\n169#PB:      ...state.answers,\n170#VQ:      {\n171#KB:        question: \"[SKIP]\",\n172#XR:        answer: \"User skipped open questions. Proceeding with best-effort planning.\",\n173#PW:      },\n174#ZB:    ],\n175#JS:  };\n176#TY:}\n177#HM:\n178#XW:/** Done answering — transitions from awaiting-answers to planning */\n179#ZN:export function doneAnswering(state: BrainstormState): BrainstormState {\n180#HT:  return transitionSubPhase(state, \"planning\");\n181#VQ:}\n182#NT:\n183#YT:// ============================================================================\n184#WJ:// EXTRACTED EVENT HANDLER LOGIC (for testability)\n185#NJ:// ============================================================================\n186#HN:\n187#KB:export interface BrainstormAgentEndResult {\n188#KQ:  action: \"suppress\" | \"transition-to-awaiting\" | \"transition-to-planning\" | \"advance\";\n189#PW:  questions?: string[];\n190#SH:  error?: string;\n191#SS:}\n192#KM:\n193#TW:/** Process an agent_end event during brainstorm mode.\n194#XZ: *  Returns instruction for the handler to execute. */\n195#WP:export function processBrainstormAgentEnd(\n196#RT:  state: RalplanState,\n197#WJ:  lastText: string,\n198#JB:  openQuestionsContent: string | null,\n199#MX:  detectBrainstormSignalFn: (text: string, signal: string) => boolean,\n200#BP:  detectSignalFn: (text: string, stageId: string) => boolean,\n201#RV:): BrainstormAgentEndResult {\n202#ZY:  const sub = state.brainstorm?.subPhase;\n203#QQ:\n204#ZN:  // expanding: suppress pipeline signals, check for OPEN_QUESTIONS_READY\n205#WX:  if (sub === \"expanding\") {\n206#PQ:    if (detectSignalFn(lastText, \"ralplan\")) {\n207#MT:      return { action: \"suppress\" };\n208#SW:    }\n209#YW:    if (detectBrainstormSignalFn(lastText, \"BRAINSTORM_OPEN_QUESTIONS_READY\")) {\n210#JW:      let questions: string[] = [];\n211#PR:      if (openQuestionsContent) {\n212#XZ:        questions = parseOpenQuestions(openQuestionsContent);\n213#KX:      }\n214#VQ:      if (questions.length === 0) {\n215#ZK:        return { action: \"transition-to-planning\", error: \"No open questions found. Proceeding directly to planning.\" };\n216#MV:      }\n217#XY:      return { action: \"transition-to-awaiting\", questions };\n218#YQ:    }\n219#SY:    return { action: \"suppress\" };\n220#NM:  }\n221#HT:\n222#JH:  // awaiting-answers: total signal suppression\n223#JS:  if (sub === \"awaiting-answers\") {\n224#SY:    return { action: \"suppress\" };\n225#SX:  }\n226#XJ:\n227#WM:  // planning: allow normal pipeline advancement\n228#PK:  if (sub === \"planning\") {\n229#PQ:    if (detectSignalFn(lastText, \"ralplan\")) {\n230#YW:      return { action: \"advance\" };\n231#MS:    }\n232#YY:  }\n233#YZ:\n234#HR:  return { action: \"suppress\" };\n235#JZ:}\n236#WZ:\n237#NQ:export interface BrainstormInputResult {\n238#SP:  appendAnswer: QandA;\n239#BV:  suppressGate: boolean;\n240#MP:}\n241#QW:\n242#PW:/** Process an input event during brainstorm awaiting-answers */\n243#NZ:export function processBrainstormInput(\n244#RT:  state: RalplanState,\n245#YH:  rawText: string,\n246#QK:): BrainstormInputResult {\n247#JZ:  const questions = state.brainstorm?.questions ?? [];\n248#ZV:  return {\n249#SQ:    appendAnswer: parseUserAnswer(rawText.trim(), questions),\n250#NQ:    suppressGate: true,\n251#ZK:  };\n252#HQ:}"}],"details":{"snapshotId":"v1|/Users/applesucks/dev/pi-ralplan/pi/extensions/ralplan/brainstorm.ts|1777218496947.5808|8408","metrics":{"truncated":false}},"isError":false,"timestamp":1779434401546}}
