 50#PR:      parsed.version = 2;\n 51#YS:      parsed.mode = \"ralplan\";\n 52#TZ:      // brainstorm and answersPath are undefined — correct for v1\n 53#BT:    }\n 54#WQ:    // v2 → v3 migration: add worktreePath\n 55#QH:    if (parsed.version === 2) {\n 56#SJ:      parsed.version = 3;\n 57#XW:      // worktreePath will be undefined — correct for v2\n 58#BZ:    }\n 59#VQ:    return parsed as unknown as RalplanState;\n 60#PZ:  } catch {\n 61#MW:    return null;\n 62#MX:  }\n 63#SP:}\n 64#XZ:\n 65#RJ:/** Write ralplan state to file */\n 66#BH:export function writeRalplanStateFile(\n 67#HH:  directory: string,\n 68#RT:  state: RalplanState,\n 69#XJ:): void {\n 70#TM:  const path = resolveStatePath(directory);\n 71#ZP:  mkdirSync(dirname(path), { recursive: true });\n 72#VN:  writeFileSync(path, JSON.stringify(state, null, 2), \"utf-8\");\n 73#XV:}\n 74#HQ:\n 75#NN:/** Clear ralplan state file */\n 76#VB:export function clearRalplanStateFile(directory: string): void {\n 77#TM:  const path = resolveStatePath(directory);\n 78#JQ:  try {\n 79#KX:    if (existsSync(path)) {\n 80#VQ:      unlinkSync(path);\n 81#XQ:    }\n 82#PZ:  } catch {\n 83#SZ:    // ignore\n 84#WH:  }\n 85#MS:}\n 86#KR:\n 87#SB:import { createBrainstormState } from \"./brainstorm.js\";\n 88#VS:\n 89#WV:/** Build default state for a new ralplan session */\n 90#SB:export function buildDefaultState(\n 91#TY:  idea: string,\n 92#RQ:  pipeline: PipelineTracking,\n 93#NP:  sessionId?: string,\n 94#TR:  mode: RalplanMode = \"ralplan\",\n 95#VZ:  directory?: string,\n 96#PJ:): RalplanState {\n 97#RJ:  const state: RalplanState = {\n 98#QY:    version: CURRENT_VERSION,\n 99#QP:    active: true,\n100#XX:    mode,\n101#KV:    pipeline,\n102#XH:    originalIdea: idea,\n103#NQ:    specPath: `plans/${getDefaultArtifactFilename(\"spec\")}`,\n104#HY:    planPath: `plans/${getDefaultArtifactFilename(\"plan\")}`,\n105#HQ:    sessionId,\n106#YV:    startedAt: new Date().toISOString(),\n107#PB:    worktreePath: undefined, // Set after worktree creation\n108#NY:  };\n109#BP:\n110#ZR:  if (mode === \"brainstorm\") {\n111#YW:    state.brainstorm = createBrainstormState();\n112#KS:    state.answersPath = directory\n113#QY:      ? resolveAnswersPath(directory)\n114#WR:      : \"plans/answers.md\";\n115#PR:  }\n116#BK:\n117#BY:  return state;\n118#WX:}"}],"details":{"snapshotId":"v1|/Users/applesucks/dev/pi-ralplan/pi/extensions/ralplan/state.ts|1779131827991.4807|3138","metrics":{"truncated":false}},"isError":false,"timestamp":1779434401546}}
