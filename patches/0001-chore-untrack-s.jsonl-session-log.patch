# Fix Cycle\n276#MH:\n277#TN:For each failure:\n278#NB:\n279#YV:1. **Diagnose** - Understand the error\n280#BX:2. **Fix** - Apply the fix with minimal changes\n281#PW:3. **Re-run** - Verify the fix worked\n282#KQ:4. **Repeat** - Until pass or max cycles (5)\n283#RS:\n284#WP:### Exit Conditions\n285#BX:\n286#TW:- All checks pass → Signal: ${QA_COMPLETION_SIGNAL}\n287#QV:- Max cycles reached → Report failures\n288#SK:- Same error 3 times → Escalate to user`;\n289#XV:}\n290#YM:\n291#JX:/** Generate the ralph verification prompt */\n292#ZY:export function getRalphPrompt(\n293#KK:  specPath: string,\n294#PS:  maxIterations: number,\n295#XJ:): string {\n296#RY:  return `## VERIFICATION (RALPH)\n297#QN:\n298#NV:Verify the implementation against the specification using the Ralph verification loop.\n299#XN:\n300#NW:**Max Iterations:** ${maxIterations}\n301#RM:\n302#SQ:### Verification Process\n303#NK:\n304#KN:Spawn parallel verification reviewers:\n305#NN:\n306#VK:Each reviewer must return ONLY a concise review summary under 100 words covering verdict, evidence highlights, files checked, and blockers. Avoid dumping long logs or transcripts into the main session.\n307#RB:\n308#WZ:\\`\\`\\`\n309#BY:// Functional Completeness Review\n310#WB:Task(\n311#XW:  agent=\"architect\",\n312#RM:  prompt=\"FUNCTIONAL COMPLETENESS REVIEW\n313#XS:\n314#JZ:Read the original spec at: ${specPath}\n315#TH:\n316#BP:Verify:\n317#JZ:1. All functional requirements are implemented\n318#KP:2. All non-functional requirements are addressed\n319#YW:3. All acceptance criteria from the plan are met\n320#XK:4. No missing features or incomplete implementations\n321#JW:\n322#ZT:Verdict: APPROVED (all requirements met) or REJECTED (with specific gaps)\"\n323#MT:)\n324#NW:\n325#VK:// Security Review\n326#WB:Task(\n327#HB:  agent=\"security-reviewer\",\n328#WH:  prompt=\"SECURITY REVIEW\n329#RX:\n330#RZ:Check the implementation for:\n331#JN:1. OWASP Top 10 vulnerabilities\n332#RY:2. Input validation and sanitiz