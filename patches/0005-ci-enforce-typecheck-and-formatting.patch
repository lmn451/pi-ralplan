     .replace(/PIPELINE_QA_COMPLETE/g, "PIPELINE\\_QA\\_COMPLETE")
-    .replace(/BRAINSTORM_OPEN_QUESTIONS_READY/g, "BRAINSTORM\\_OPEN\\_QUESTIONS\\_READY");
+    .replace(
+      /BRAINSTORM_OPEN_QUESTIONS_READY/g,
