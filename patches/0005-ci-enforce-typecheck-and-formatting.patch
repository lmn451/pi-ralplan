From 5ead9a0daf1f506a4af5340b44bf72c129548386 Mon Sep 17 00:00:00 2001
From: Michael Lerman <mlerman@ironscales.com>
Date: Tue, 9 Jun 2026 14:24:19 +0300
Subject: [PATCH 5/6] ci: enforce typecheck and formatting

Add 'tsc --noEmit' and 'prettier --check' steps to CI so type and format
regressions fail the build (husky only covers staged files locally).
Reformats pre-existing files to satisfy the new prettier gate.

Co-authored-by: Cursor <cursoragent@cursor.com>
---
 .github/workflows/ci.yml            |  2 +
 pi/extensions/ralplan/brainstorm.ts | 35 +++++++++++----
 tests/brainstorm.test.ts            | 66 +++++++++++++++++++++++------
 tests/naming.test.ts                |  2 +-
 4 files changed, 82 insertions(+), 23 deletions(-)

diff --git a/.github/workflows/ci.yml b/.github/workflows/ci.yml
index d3b5691..62be0fd 100644
--- a/.github/workflows/ci.yml
+++ b/.github/workflows/ci.yml
@@ -19,4 +19,6 @@ jobs:
           node-version: 24
           cache: npm
       - run: npm ci
+      - run: npx tsc --noEmit
+      - run: npx prettier --check "pi/**/*.ts" "tests/**/*.ts"
       - run: npm test
