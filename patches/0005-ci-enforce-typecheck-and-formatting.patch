       .slice(headingMatch.index + headingMatch[0].length)
       .replace(/^\r?\n/, "");
     const nextHeadingIndex = afterHeading.search(/\r?\n##\s+/);
-    const section = (nextHeadingIndex >= 0
-      ? afterHeading.slice(0, nextHeadingIndex)
-      : afterHeading).trim();
+    const section = (
+      nextHeadingIndex >= 0
+        ? afterHeading.slice(0, nextHeadingIndex)
